---
// 这个组件会在客户端通过 JavaScript 动态生成目录
// Astro 静态生成时无法获取文章内容中的 headings
---

<div id="toc-container" class="my-8 p-6 rounded-2xl bg-muted/50 border border-foreground/10 hidden">
  <h3 class="text-lg font-bold mb-4 flex items-center gap-2">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
    </svg>
    <span>目录</span>
  </h3>
  <nav id="toc-list" class="space-y-2">
    <!-- 目录将通过 JavaScript 动态生成 -->
  </nav>
</div>

<script>
  // 在客户端生成目录
  document.addEventListener('DOMContentLoaded', () => {
    const article = document.getElementById('article');
    const tocContainer = document.getElementById('toc-container');
    const tocList = document.getElementById('toc-list');
    
    if (!article || !tocContainer || !tocList) return;
    
    // 获取所有 h2, h3, h4 标题
    const headings = article.querySelectorAll('h2, h3, h4');
    
    if (headings.length === 0) {
      tocContainer.style.display = 'none';
      return;
    }
    
    // 生成目录项
    headings.forEach((heading) => {
      if (!heading.id) {
        // 如果没有 id，生成一个
        heading.id = heading.textContent!.toLowerCase().replace(/[^\w]+/g, '-');
      }
      
      const depth = parseInt(heading.tagName.charAt(1));
      const link = document.createElement('a');
      link.href = `#${heading.id}`;
      link.className = 'block hover:text-accent transition-colors';
      link.textContent = heading.textContent!;
      
      // 根据层级设置缩进
      if (depth === 2) {
        link.classList.add('pl-0');
        link.style.fontSize = '1rem';
        link.innerHTML = `<span class="text-accent mr-2">📌</span>${heading.textContent}`;
      } else if (depth === 3) {
        link.classList.add('pl-4');
        link.style.fontSize = '0.95rem';
        link.innerHTML = `<span class="text-foreground/50 mr-2">•</span>${heading.textContent}`;
      } else if (depth === 4) {
        link.classList.add('pl-8');
        link.style.fontSize = '0.9rem';
      }
      
      tocList.appendChild(link);
    });
    
    // 显示目录容器
    tocContainer.style.display = 'block';
  });
</script>
