---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE, SITE_DESCRIPTION, SITE, TECH_STACK, FEATURED_PROJECTS } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			/* Hero Section */
			.hero {
				text-align: center;
				padding: 5rem 1rem;
				background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
				color: white;
				margin-bottom: 3rem;
			}
			.hero-avatar {
				width: 150px;
				height: 150px;
				border-radius: 50%;
				border: 4px solid white;
				margin-bottom: 1.5rem;
				background: #fff;
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 4rem;
				margin-left: auto;
				margin-right: auto;
			}
			.hero h1 {
				font-size: 2.5rem;
				margin-bottom: 0.5rem;
				color: white;
			}
			.hero p {
				font-size: 1.25rem;
				opacity: 0.9;
				margin-bottom: 1.5rem;
			}
			.hero-links {
				display: flex;
				gap: 1rem;
				justify-content: center;
				flex-wrap: wrap;
			}
			.hero-links a {
				color: white;
				text-decoration: none;
				padding: 0.5rem 1.5rem;
				border: 2px solid white;
				border-radius: 25px;
				transition: all 0.3s;
			}
			.hero-links a:hover {
				background: white;
				color: #667eea;
			}

			/* Section Styles */
			section {
				max-width: 1000px;
				margin: 0 auto;
				padding: 2rem 1rem;
			}
			h2 {
				font-size: 2rem;
				margin-bottom: 1.5rem;
				color: #333;
				border-bottom: 3px solid #667eea;
				padding-bottom: 0.5rem;
				display: inline-block;
			}

			/* About Section */
			.about {
				background: #f8f9fa;
				border-radius: 10px;
				padding: 2rem;
				margin-bottom: 3rem;
			}
			.about p {
				line-height: 1.8;
				color: #555;
			}

			/* Projects Grid */
			.projects-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
				gap: 1.5rem;
			}
			.project-card {
				background: white;
				border: 1px solid #e0e0e0;
				border-radius: 10px;
				padding: 1.5rem;
				transition: transform 0.3s, box-shadow 0.3s;
			}
			.project-card:hover {
				transform: translateY(-5px);
				box-shadow: 0 10px 20px rgba(0,0,0,0.1);
			}
			.project-card h3 {
				color: #667eea;
				margin-bottom: 0.5rem;
			}
			.project-card p {
				color: #666;
				line-height: 1.6;
				margin-bottom: 1rem;
			}
			.project-tags {
				display: flex;
				gap: 0.5rem;
				flex-wrap: wrap;
				margin-bottom: 1rem;
			}
			.tag {
				background: #667eea;
				color: white;
				padding: 0.25rem 0.75rem;
				border-radius: 15px;
				font-size: 0.85rem;
			}
			.project-link {
				display: inline-block;
				color: #667eea;
				text-decoration: none;
				font-weight: 600;
			}
			.project-link:hover {
				text-decoration: underline;
			}

			/* Tech Stack */
			.tech-stack {
				display: flex;
				flex-wrap: wrap;
				gap: 1rem;
				justify-content: center;
			}
			.tech-item {
				background: white;
				border: 2px solid #667eea;
				border-radius: 10px;
				padding: 1rem 1.5rem;
				display: flex;
				align-items: center;
				gap: 0.5rem;
				font-weight: 600;
				color: #333;
				transition: all 0.3s;
			}
			.tech-item:hover {
				background: #667eea;
				color: white;
				transform: scale(1.05);
			}

			/* CTA Section */
			.cta {
				text-align: center;
				padding: 3rem 1rem;
				background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
				color: white;
				border-radius: 10px;
				margin-top: 3rem;
			}
			.cta h2 {
				color: white;
				border-bottom: none;
			}
			.cta a {
				display: inline-block;
				margin-top: 1rem;
				padding: 0.75rem 2rem;
				background: white;
				color: #667eea;
				text-decoration: none;
				border-radius: 25px;
				font-weight: 600;
				transition: all 0.3s;
			}
			.cta a:hover {
				transform: scale(1.05);
				box-shadow: 0 5px 15px rgba(0,0,0,0.2);
			}

			/* Responsive */
			@media (max-width: 600px) {
				.hero h1 {
					font-size: 2rem;
				}
				.hero p {
					font-size: 1rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		
		<main>
			<!-- Hero Section -->
			<div class="hero">
				<div class="hero-avatar">👨‍💻</div>
				<h1>Hi, I'm CloudZun</h1>
				<p>{SITE_DESCRIPTION}</p>
				<div class="hero-links">
					<a href={SITE.github} target="_blank" rel="noopener">GitHub</a>
					<a href="/blog">Blog</a>
					<a href="/about">About</a>
					<a href="mailto:{SITE.email}">Contact</a>
				</div>
			</div>

			<!-- About Section -->
			<section>
				<div class="about">
					<h2>About Me</h2>
					<p>
						我是一名热爱 AI 和自动化的工程师，专注于构建智能 Agent 系统和自动化工作流。
						目前活跃于 OpenClaw 生态系统，已开发 50+ 个技能，涵盖投资分析、内容生成、数据处理等多个领域。
					</p>
					<p>
						除了技术开发，我还热衷于知识分享，正在开发 Microsoft OpenCode 课程，帮助学生掌握 AI Agent 的实际应用。
						我相信技术应该服务于人，让复杂的事情变得简单。
					</p>
				</div>
			</section>

			<!-- Tech Stack -->
			<section>
				<h2>Tech Stack</h2>
				<div class="tech-stack">
					{TECH_STACK.map((tech) => (
						<div class="tech-item">
							<span>{tech.icon}</span>
							<span>{tech.name}</span>
						</div>
					))}
				</div>
			</section>

			<!-- Featured Projects -->
			<section>
				<h2>Featured Projects</h2>
				<div class="projects-grid">
					{FEATURED_PROJECTS.map((project) => (
						<div class="project-card">
							<h3>{project.name}</h3>
							<div class="project-tags">
								{project.tags.map((tag) => (
									<span class="tag">{tag}</span>
								))}
							</div>
							<p>{project.description}</p>
							<a href={project.repo} class="project-link" target="_blank" rel="noopener">
								View on GitHub →
							</a>
						</div>
					))}
				</div>
			</section>

			<!-- Latest Blog Posts -->
			<section>
				<h2>Latest Posts</h2>
				<p style="text-align: center; color: #666;">
					<a href="/blog" style="color: #667eea; text-decoration: none; font-weight: 600;">
						View all posts →
					</a>
				</p>
			</section>

			<!-- CTA -->
			<section>
				<div class="cta">
					<h2>Let's Work Together</h2>
					<p>有项目想法？想聊聊技术？随时联系我！</p>
					<a href={`mailto:${SITE.email}`}>Get in Touch</a>
				</div>
			</section>
		</main>

		<Footer />
	</body>
</html>
