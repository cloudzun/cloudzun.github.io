---
import { getCollection } from "astro:content";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";

const posts = await getCollection("blog");

// 定义分类
const categories = {
  "AI 协同编程": {
    id: "ai-coding",
    desc: "OpenCode、Claude Code、多 Agent 工作流、SDD 规格驱动开发",
    keywords: ["openclaw", "opencode", "claude code", "agent", "sdd", "协同编程", "ai 编程"],
    color: "bg-blue-500 hover:bg-blue-600"
  },
  "Vibe Coding": {
    id: "vibe-coding",
    desc: "放手让 AI 写代码的边界与质量保障机制",
    keywords: ["vibe coding", "vibe", "7-gate", "质量门控", "迭代"],
    color: "bg-purple-500 hover:bg-purple-600"
  },
  "办公自动化": {
    id: "automation",
    desc: "Microsoft 365 Copilot、Excel/Word/PPT 自动化、Vibe Working",
    keywords: ["办公自动化", "microsoft", "excel", "word", "ppt", "vibe working", "copilot"],
    color: "bg-green-500 hover:bg-green-600"
  },
  "技术思考": {
    id: "thinking",
    desc: "架构决策、技术复盘、AI 时代的开发流程重构",
    keywords: ["思考", "复盘", "反思", "架构", "流程", "copilot", "opencode"],
    color: "bg-orange-500 hover:bg-orange-600"
  },
  "工程实践": {
    id: "practice",
    desc: "架构决策记录、技术债管理、Docker 部署、项目实战",
    keywords: ["工程", "部署", "docker", "架构", "实战", "项目"],
    color: "bg-cyan-500 hover:bg-cyan-600"
  }
};

// 为每篇文章匹配分类
const postsByCategory = Object.entries(categories).map(([name, { id, keywords }]) => {
  const categoryPosts = posts.filter(post => {
    const title = post.data.title.toLowerCase();
    const tags = post.data.tags?.map(t => t.toLowerCase()) || [];
    const description = post.data.description?.toLowerCase() || "";
    
    return keywords.some(keyword => 
      title.includes(keyword.toLowerCase()) || 
      tags.some(tag => tag.includes(keyword.toLowerCase())) ||
      description.includes(keyword.toLowerCase())
    );
  });
  
  return {
    name,
    id,
    desc: categories[name as keyof typeof categories].desc,
    color: categories[name as keyof typeof categories].color,
    count: categoryPosts.length,
    posts: categoryPosts.sort((a, b) => 
      new Date(b.data.pubDatetime).getTime() - new Date(a.data.pubDatetime).getTime()
    )
  };
}).filter(cat => cat.count > 0);
---

<Layout title={`Categories | ${SITE.title}`}>
  <Header />
  <Main pageTitle="文章分类" pageDesc="按主题浏览博客文章">
    <!-- 分类按钮 -->
    <div class="mb-10">
      <h3 class="text-xl font-bold mb-6 text-center">📂 选择分类</h3>
      <div class="flex flex-wrap justify-center gap-4">
        {postsByCategory.map(({ name, id, count, color }) => (
          <button
            id={`btn-${id}`}
            onclick={`showCategory('${id}')`}
            class:list={[
              "px-8 py-4 rounded-xl font-bold text-white transition-all transform hover:scale-105",
              color,
              "shadow-lg hover:shadow-xl"
            ]}
          >
            {name}
            <span class="ml-2 px-3 py-1 rounded-full bg-white/30 text-sm">
              {count} 篇
            </span>
          </button>
        ))}
      </div>
    </div>

    <!-- 分类文章列表 -->
    {postsByCategory.map(({ name, id, desc, posts: categoryPosts }) => (
      <div id={`category-${id}`} class="category-section hidden scroll-mt-20">
        <div class="mb-8 p-6 rounded-2xl bg-gradient-to-r from-muted/80 to-muted/40 border-2 border-foreground/10">
          <h3 class="text-2xl font-bold mb-2">{name}</h3>
          <p class="text-foreground/70">{desc}</p>
          <div class="mt-4 flex items-center gap-4">
            <span class="px-4 py-2 rounded-full bg-accent text-white font-bold text-sm">
              {categoryPosts.length} 篇文章
            </span>
            <button
              onclick={`hideCategory('${id}')`}
              class="text-foreground/60 hover:text-accent transition-colors text-sm underline"
            >
              收起 ↑
            </button>
          </div>
        </div>

        <!-- 文章列表 -->
        <div class="space-y-4 mb-12">
          {categoryPosts.map(post => (
            <a
              href={`/posts/${post.id}/`}
              class="block p-6 rounded-xl bg-muted/50 hover:bg-accent/10 transition-all group border border-foreground/5 hover:border-accent/30"
            >
              <div class="flex items-start justify-between gap-4">
                <div class="flex-1">
                  <h4 class="text-lg font-bold group-hover:text-accent transition-colors mb-2">
                    {post.data.title}
                  </h4>
                  <p class="text-foreground/70 mb-3 line-clamp-2">
                    {post.data.description}
                  </p>
                  <div class="flex items-center gap-4 text-sm text-foreground/60">
                    <span>
                      📅 {new Date(post.data.pubDatetime).toLocaleDateString('zh-CN', {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric'
                      })}
                    </span>
                    {post.data.tags?.length > 0 && (
                      <div class="flex items-center gap-2">
                        <span>•</span>
                        <div class="flex flex-wrap gap-1">
                          {post.data.tags.slice(0, 3).map(tag => (
                            <span class="px-2 py-0.5 rounded bg-muted text-xs">
                              {tag}
                            </span>
                          ))}
                        </div>
                      </div>
                    )}
                  </div>
                </div>
                <span class="text-accent text-sm font-medium whitespace-nowrap flex items-center">
                  阅读
                  <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    ))}

    <!-- 统计信息 -->
    <div class="mt-12 p-6 rounded-2xl bg-gradient-to-r from-muted/50 to-muted/30 border border-foreground/10">
      <h3 class="text-xl font-bold mb-6 text-center">📊 分类统计</h3>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
        {postsByCategory.map(({ name, count }) => (
          <div class="text-center">
            <div class="text-3xl font-bold text-accent mb-2">{count}</div>
            <div class="text-sm text-foreground/70">{name}</div>
          </div>
        ))}
      </div>
    </div>
  </Main>
  <Footer />
</Layout>

<script is:inline>
  // 使函数在全局作用域可用
  window.showCategory = function(id) {
    console.log('Showing category:', id);
    
    // 隐藏所有分类
    document.querySelectorAll('.category-section').forEach(el => {
      el.classList.add('hidden');
    });
    
    // 显示选中的分类
    const target = document.getElementById('category-' + id);
    if (target) {
      target.classList.remove('hidden');
      // 平滑滚动到分类位置
      target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  };

  window.hideCategory = function(id) {
    const target = document.getElementById('category-' + id);
    if (target) {
      target.classList.add('hidden');
      // 滚动回顶部
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  };

  // 页面加载时检查 URL hash
  document.addEventListener('DOMContentLoaded', function() {
    const hash = window.location.hash.slice(1);
    if (hash) {
      // 检查是否是分类 ID
      const categoryIds = ['ai-coding', 'vibe-coding', 'automation', 'thinking', 'practice'];
      if (categoryIds.includes(hash)) {
        window.showCategory(hash);
      }
    }
  });
</script>
