---
import { getCollection } from "astro:content";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import getUniqueTags from "@/utils/getUniqueTags";
import { SITE } from "@/config";

const posts = await getCollection("blog");
const tagsData = getUniqueTags(posts);

// 计算每个标签的使用次数
const tagsWithCount = tagsData.map(({ tag, tagName }) => {
  const count = posts.filter(post => 
    post.data.tags?.map(t => t.toLowerCase()).includes(tag)
  ).length;
  return { tag, tagName, count };
});

// 按使用次数排序
tagsWithCount.sort((a, b) => b.count - a.count);

// 计算字体大小（基于使用次数）
const maxCount = Math.max(...tagsWithCount.map(t => t.count));
const minCount = Math.min(...tagsWithCount.map(t => t.count));

const getFontSize = (count: number) => {
  if (maxCount === minCount) return "text-xl";
  
  const ratio = (count - minCount) / (maxCount - minCount);
  
  if (ratio >= 0.8) return "text-3xl font-bold";
  if (ratio >= 0.6) return "text-2xl font-semibold";
  if (ratio >= 0.4) return "text-xl font-medium";
  if (ratio >= 0.2) return "text-lg";
  return "text-base";
};

const getColor = (count: number) => {
  const ratio = (count - minCount) / (maxCount - minCount);
  
  if (ratio >= 0.8) return "text-accent";
  if (ratio >= 0.6) return "text-foreground/90";
  if (ratio >= 0.4) return "text-foreground/80";
  if (ratio >= 0.2) return "text-foreground/70";
  return "text-foreground/60";
};
---

<Layout title={`Tags | ${SITE.title}`}>
  <Header />
  <Main pageTitle="Tags" pageDesc="通过标签词云探索博客内容">
    <!-- 统计面板 - 移到顶部 -->
    <div class="mb-10 p-6 rounded-lg bg-gradient-to-r from-muted/50 to-muted/30 border border-foreground/10">
      <h3 class="text-xl font-semibold mb-6 text-center">📊 博客内容概览</h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="text-center">
          <div class="text-4xl font-bold text-accent mb-2">{posts.length}</div>
          <div class="text-sm text-foreground/70">📝 总文章数</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-bold text-accent mb-2">{tagsWithCount.length}</div>
          <div class="text-sm text-foreground/70">🏷️ 总标签数</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-bold text-accent mb-2">{maxCount}</div>
          <div class="text-sm text-foreground/70">🔥 最高频标签使用次数</div>
        </div>
        <div class="text-center">
          <a
            href="/tags/"
            class="inline-block px-6 py-3 rounded bg-accent text-white font-medium hover:opacity-90 transition-opacity"
          >
            📋 查看列表视图 →
          </a>
        </div>
      </div>

      <!-- Top 10 热门标签 -->
      <div class="mt-8 pt-6 border-t border-foreground/10">
        <h4 class="font-medium mb-4 text-center text-foreground/80">🏆 热门标签 Top 10</h4>
        <ol class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-3">
          {tagsWithCount.slice(0, 10).map(({ tagName, count }, index) => (
            <li class="flex items-center justify-between px-4 py-2 rounded-lg bg-white/50 hover:bg-accent/10 transition-colors">
              <div class="flex items-center gap-3">
                <span class="text-lg font-bold text-accent w-6">#{index + 1}</span>
                <span class="font-medium">{tagName}</span>
              </div>
              <span class="text-sm text-accent font-medium">{count} 次</span>
            </li>
          ))}
        </ol>
      </div>
    </div>

    <!-- 切换按钮 -->
    <div class="mb-6 flex justify-center gap-4">
      <a
        href="/tags/"
        class="px-6 py-2 rounded-lg border-2 border-foreground/30 hover:bg-accent hover:text-white hover:border-accent transition-all font-medium"
      >
        📋 列表视图
      </a>
      <button
        disabled
        class="px-6 py-2 rounded-lg bg-accent text-white font-medium cursor-not-allowed"
      >
        🌩️ 词云视图
      </button>
    </div>

    <!-- 词云 -->
    <div class="mb-12">
      <h4 class="text-lg font-semibold mb-6 text-center text-foreground/80">🌩️ 标签词云</h4>
      <div class="flex flex-wrap gap-4 py-8 justify-center">
        {tagsWithCount.map(({ tag, tagName, count }) => (
          <a
            href={`/tags/${tag}/`}
            transition:name={tag}
            class:list={[
              "inline-block transition-all duration-200",
              "hover:-translate-y-1 hover:opacity-80",
              getFontSize(count),
              getColor(count),
            ]}
            style={`display: inline-block; margin: 4px;`}
          >
            {tagName}
            <span class="text-sm opacity-60 ml-1">({count})</span>
          </a>
        ))}
      </div>
    </div>
  </Main>
  <Footer />
</Layout>
