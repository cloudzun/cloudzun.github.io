---
import { getCollection } from "astro:content";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import getUniqueTags from "@/utils/getUniqueTags";
import { SITE } from "@/config";

const posts = await getCollection("blog");
const tagsData = getUniqueTags(posts);

// 计算每个标签的使用次数
const tagsWithCount = tagsData.map(({ tag, tagName }) => {
  const count = posts.filter(post => 
    post.data.tags?.map(t => t.toLowerCase()).includes(tag)
  ).length;
  return { tag, tagName, count };
});

// 按使用次数排序
tagsWithCount.sort((a, b) => b.count - a.count);

const maxCount = Math.max(...tagsWithCount.map(t => t.count));
const avgCount = (tagsWithCount.reduce((sum, t) => sum + t.count, 0) / tagsWithCount.length).toFixed(1);
---

<Layout title={`Tags | ${SITE.title}`}>
  <Header />
  <Main pageTitle="Tags" pageDesc="通过标签探索博客内容">
    <!-- 统计面板 -->
    <div class="mb-10 p-8 rounded-2xl bg-gradient-to-br from-muted/80 to-muted/40 border-2 border-foreground/10 shadow-lg">
      <h3 class="text-2xl font-bold mb-8 text-center flex items-center justify-center gap-3">
        <span class="text-3xl">📊</span>
        <span>标签统计</span>
      </h3>
      
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="text-5xl font-bold text-accent mb-3">{tagsWithCount.length}</div>
          <div class="text-sm text-foreground/70 font-medium">总标签数</div>
        </div>
        <div class="text-center">
          <div class="text-5xl font-bold text-accent mb-3">{posts.length}</div>
          <div class="text-sm text-foreground/70 font-medium">总文章数</div>
        </div>
        <div class="text-center">
          <div class="text-5xl font-bold text-accent mb-3">{maxCount}</div>
          <div class="text-sm text-foreground/70 font-medium">最多使用的标签</div>
        </div>
        <div class="text-center">
          <div class="text-5xl font-bold text-accent mb-3">{avgCount}</div>
          <div class="text-sm text-foreground/70 font-medium">平均每标签使用次数</div>
        </div>
      </div>

      <!-- Top 10 热门标签 -->
      <div class="mt-10 pt-8 border-t-2 border-foreground/10">
        <h4 class="text-xl font-bold mb-6 flex items-center gap-2">
          <span class="text-2xl">🏆</span>
          <span>Top 10 热门标签</span>
        </h4>
        <div class="space-y-3">
          {tagsWithCount.slice(0, 10).map(({ tag, tagName, count }, index) => {
            const rankColors = [
              'text-yellow-500', // #1
              'text-gray-400',   // #2
              'text-amber-600',  // #3
              'text-foreground/70',
              'text-foreground/70',
              'text-foreground/70',
              'text-foreground/70',
              'text-foreground/70',
              'text-foreground/70',
              'text-foreground/70',
            ];
            return (
              <div class="flex items-center justify-between py-3 px-4 rounded-lg hover:bg-accent/10 transition-colors group">
                <div class="flex items-center gap-4">
                  <span class={`text-lg font-bold w-8 ${rankColors[index]}`}>#{index + 1}</span>
                  <a 
                    href={`/tags/${tag}/`}
                    class="font-medium text-lg group-hover:text-accent transition-colors"
                  >
                    {tagName}
                  </a>
                </div>
                <span class="text-accent font-semibold">{count} 次</span>
              </div>
            );
          })}
        </div>
      </div>
    </div>

    <!-- 切换按钮 -->
    <div class="mb-8 flex justify-center gap-4">
      <button
        disabled
        class="px-8 py-3 rounded-xl bg-accent text-white font-medium cursor-not-allowed text-lg"
      >
        📊 统计视图
      </button>
      <a
        href="/tags/cloud/"
        class="px-8 py-3 rounded-xl border-2 border-foreground/30 hover:bg-accent hover:text-white hover:border-accent transition-all font-medium text-lg"
      >
        🌩️ 词云视图
      </a>
    </div>

    <!-- 完整标签列表 -->
    <div class="mb-12">
      <h4 class="text-xl font-bold mb-6 text-center">📑 全部标签</h4>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {tagsWithCount.map(({ tag, tagName, count }) => (
          <a
            href={`/tags/${tag}/`}
            class="flex items-center justify-between px-4 py-3 rounded-lg bg-muted/50 hover:bg-accent/10 transition-all group"
          >
            <span class="font-medium group-hover:text-accent transition-colors">{tagName}</span>
            <span class="text-sm text-accent font-semibold">{count}</span>
          </a>
        ))}
      </div>
    </div>
  </Main>
  <Footer />
</Layout>
