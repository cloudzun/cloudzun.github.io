---
import { getCollection } from "astro:content";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Tag from "@/components/Tag.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import getUniqueTags from "@/utils/getUniqueTags";
import { SITE } from "@/config";

const posts = await getCollection("blog");

let tags = getUniqueTags(posts);
---

<Layout title={`Tags | ${SITE.title}`}>
  <Header />
  <Main pageTitle="Tags" pageDesc="通过标签探索博客内容">
    <!-- 统计面板 - 移到顶部 -->
    <div class="mb-10 p-6 rounded-lg bg-gradient-to-r from-muted/50 to-muted/30 border border-foreground/10">
      <h3 class="text-xl font-semibold mb-6 text-center">📊 博客内容概览</h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="text-center">
          <div class="text-4xl font-bold text-accent mb-2">{posts.length}</div>
          <div class="text-sm text-foreground/70">📝 总文章数</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-bold text-accent mb-2">{tags.length}</div>
          <div class="text-sm text-foreground/70">🏷️ 总标签数</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-bold text-accent mb-2">{(posts.length / tags.length).toFixed(1)}</div>
          <div class="text-sm text-foreground/70">📈 平均每标签文章数</div>
        </div>
        <div class="text-center">
          <a
            href="/tags/cloud/"
            class="inline-block px-6 py-3 rounded bg-accent text-white font-medium hover:opacity-90 transition-opacity"
          >
            🌩️ 查看词云视图 →
          </a>
        </div>
      </div>

      <!-- Top 10 热门标签 -->
      <div class="mt-8 pt-6 border-t border-foreground/10">
        <h4 class="font-medium mb-4 text-center text-foreground/80">🏆 热门标签 Top 10</h4>
        <div class="flex flex-wrap justify-center gap-3">
          {tags.slice(0, 10).map(({ tag, tagName }) => {
            const count = posts.filter(post => 
              post.data.tags?.map(t => t.toLowerCase()).includes(tag)
            ).length;
            return (
              <a
                href={`/tags/${tag}/`}
                class="px-4 py-2 rounded-full bg-accent/10 text-accent hover:bg-accent hover:text-white transition-all text-sm font-medium"
              >
                {tagName} · {count}篇
              </a>
            );
          })}
        </div>
      </div>
    </div>

    <!-- 切换按钮 -->
    <div class="mb-6 flex justify-center gap-4">
      <button
        disabled
        class="px-6 py-2 rounded-lg bg-accent text-white font-medium cursor-not-allowed"
      >
        📋 列表视图
      </button>
      <a
        href="/tags/cloud/"
        class="px-6 py-2 rounded-lg border-2 border-foreground/30 hover:bg-accent hover:text-white hover:border-accent transition-all font-medium"
      >
        🌩️ 词云视图
      </a>
    </div>

    <!-- 标签列表 -->
    <div class="mb-12">
      <h4 class="text-lg font-semibold mb-6 text-center text-foreground/80">📑 所有标签</h4>
      <ul class="flex flex-wrap gap-6 justify-center">
        {tags.map(({ tag, tagName }) => <Tag {tag} {tagName} />)}
      </ul>
    </div>
  </Main>
  <Footer />
</Layout>
