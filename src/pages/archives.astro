---
import { getCollection } from "astro:content";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";

const posts = await getCollection("blog");

// 按日期分组统计
const postsByDate = new Map<string, any[]>();
const postsByMonth = new Map<string, any[]>();

posts.forEach(post => {
  const date = new Date(post.data.pubDatetime);
  const year = date.getFullYear();
  const month = date.getMonth();
  const day = date.getDate();
  const dateKey = `${year}-${month.toString().padStart(2, '0')}-${day.toString().padStart(2, '0')}`;
  const monthKey = `${year}-${month.toString().padStart(2, '0')}`;
  
  if (!postsByDate.has(dateKey)) {
    postsByDate.set(dateKey, []);
  }
  postsByDate.get(dateKey)!.push(post);
  
  if (!postsByMonth.has(monthKey)) {
    postsByMonth.set(monthKey, []);
  }
  postsByMonth.get(monthKey)!.push(post);
});

// 获取当前年份和月份
const currentYear = new Date().getFullYear();
const currentMonth = new Date().getMonth();

// 生成最近 12 个月的月份列表
const months = [];
for (let i = 11; i >= 0; i--) {
  const date = new Date(currentYear, currentMonth - i, 1);
  const year = date.getFullYear();
  const month = date.getMonth();
  const key = `${year}-${month.toString().padStart(2, '0')}`;
  const monthNames = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
  const monthNamesCN = ['1 月', '2 月', '3 月', '4 月', '5 月', '6 月', '7 月', '8 月', '9 月', '10 月', '11 月', '12 月'];
  
  months.push({
    key,
    year,
    month,
    name: monthNames[month],
    nameCN: monthNamesCN[month],
    count: postsByMonth.get(key)?.length || 0
  });
}

// 生成日历数据（最近 365 天）
const calendarData = [];
const today = new Date();
const startDate = new Date(today);
startDate.setDate(startDate.getDate() - 364); // 包括今天是 365 天

let currentDate = new Date(startDate);
while (currentDate <= today) {
  const dateKey = currentDate.toISOString().split('T')[0];
  const count = postsByDate.get(dateKey)?.length || 0;
  const dayOfWeek = currentDate.getDay();
  
  calendarData.push({
    date: new Date(currentDate),
    dateKey,
    count,
    dayOfWeek,
    level: count === 0 ? 0 : count === 1 ? 1 : count <= 3 ? 2 : count <= 5 ? 3 : 4
  });
  
  currentDate.setDate(currentDate.getDate() + 1);
}

// 按周组织数据
const weeks: any[][] = [];
let currentWeek: any[] = [];
calendarData.forEach((day: any, index: number) => {
  currentWeek.push(day);
  if (currentWeek.length === 7 || index === calendarData.length - 1) {
    weeks.push(currentWeek);
    currentWeek = [];
  }
});

// 统计信息
const totalPosts = posts.length;
const totalDays = calendarData.filter(d => d.count > 0).length;
const maxStreak = calculateMaxStreak(calendarData);
const currentStreak = calculateCurrentStreak(calendarData);

function calculateMaxStreak(data: any[]) {
  let max = 0;
  let current = 0;
  for (const day of data) {
    if (day.count > 0) {
      current++;
      max = Math.max(max, current);
    } else {
      current = 0;
    }
  }
  return max;
}

function calculateCurrentStreak(data: any[]) {
  let current = 0;
  for (let i = data.length - 1; i >= 0; i--) {
    if (data[i].count > 0) {
      current++;
    } else {
      break;
    }
  }
  return current;
}

// 按月份分组文章
const postsByMonthList = Array.from(postsByMonth.entries())
  .map(([key, posts]) => {
    const [year, month] = key.split('-').map(Number);
    return {
      year,
      month,
      key,
      posts: posts.sort((a, b) => 
        new Date(b.data.pubDatetime).getTime() - new Date(a.data.pubDatetime).getTime()
      ),
      count: posts.length
    };
  })
  .sort((a, b) => {
    if (b.year !== a.year) return b.year - a.year;
    return b.month - a.month;
  });
---

<Layout title={`Archives | ${SITE.title}`}>
  <Header />
  <Main pageTitle="文章归档" pageDesc="GitHub Contribution 风格的写作记录">
    <!-- 统计面板 -->
    <div class="mb-10 p-6 rounded-2xl bg-gradient-to-br from-muted/80 to-muted/40 border-2 border-foreground/10">
      <h3 class="text-2xl font-bold mb-6 text-center">📊 写作统计</h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="text-center">
          <div class="text-4xl font-bold text-accent mb-2">{totalPosts}</div>
          <div class="text-sm text-foreground/70">总文章数</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-bold text-accent mb-2">{totalDays}</div>
          <div class="text-sm text-foreground/70">写作天数</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-bold text-accent mb-2">{maxStreak}</div>
          <div class="text-sm text-foreground/70">最长连续写作</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-bold text-accent mb-2">{currentStreak}</div>
          <div class="text-sm text-foreground/70">当前连续写作</div>
        </div>
      </div>
    </div>

    <!-- GitHub Contribution 风格日历 -->
    <div class="mb-12 p-6 rounded-2xl bg-gradient-to-br from-muted/80 to-muted/40 border-2 border-foreground/10 overflow-x-auto">
      <div class="flex items-baseline justify-between mb-4">
        <h3 class="text-xl font-bold">📅 最近一年写作记录</h3>
        <span class="text-sm text-foreground/60">{totalPosts} contributions in the last year</span>
      </div>
      
      <!-- 月份标签 -->
      <div class="flex gap-2 mb-2 ml-8">
        {months.map(m => (
          <div class="w-3 text-xs text-foreground/60">{m.name}</div>
        ))}
      </div>
      
      <!-- 日历网格 -->
      <div class="flex gap-1">
        {weeks.map((week: any[], weekIndex: number) => (
          <div class="flex flex-col gap-1">
            {week.map((day: any, dayIndex: number) => {
              const colorClass = day.level === 0 ? 'bg-foreground/10' :
                                day.level === 1 ? 'bg-green-200' :
                                day.level === 2 ? 'bg-green-400' :
                                day.level === 3 ? 'bg-green-600' :
                                'bg-green-800';
              
              return (
                <div
                  class={`w-3 h-3 rounded-sm ${colorClass} hover:ring-2 hover:ring-accent transition-all cursor-pointer`}
                  title={`${day.dateKey}: ${day.count}篇文章`}
                  onclick={`showDate('${day.dateKey}')`}
                />
              );
            })}
          </div>
        ))}
      </div>
      
      <!-- 图例 -->
      <div class="flex items-center gap-2 mt-4 text-xs text-foreground/60">
        <span>Less</span>
        <div class="w-3 h-3 rounded-sm bg-foreground/10"></div>
        <div class="w-3 h-3 rounded-sm bg-green-200"></div>
        <div class="w-3 h-3 rounded-sm bg-green-400"></div>
        <div class="w-3 h-3 rounded-sm bg-green-600"></div>
        <div class="w-3 h-3 rounded-sm bg-green-800"></div>
        <span>More</span>
      </div>
    </div>

    <!-- 按月份列表 -->
    <div class="space-y-8">
      {postsByMonthList.map(({ year, month, key, posts: monthPosts, count }) => {
        const monthNamesCN = ['1 月', '2 月', '3 月', '4 月', '5 月', '6 月', '7 月', '8 月', '9 月', '10 月', '11 月', '12 月'];
        const isCurrentMonth = year === currentYear && month === currentMonth;
        
        return (
          <div id={key} class="scroll-mt-20">
            <div class="flex items-center gap-3 mb-6">
              <span class="text-3xl">📌</span>
              <h3 class="text-2xl font-bold">
                {year}年{monthNamesCN[month]}
              </h3>
              {isCurrentMonth && (
                <span class="px-3 py-1 rounded-full bg-accent text-white text-xs font-bold">
                  本月
                </span>
              )}
              <span class="text-sm text-foreground/60">
                ({count} 篇)
              </span>
            </div>
            
            <div class="space-y-3">
              {monthPosts.map(post => {
                const pubDate = new Date(post.data.pubDatetime);
                const day = pubDate.getDate();
                const dayOfWeek = pubDate.getDay();
                const dayNames = ['日', '一', '二', '三', '四', '五', '六'];
                
                return (
                  <a
                    href={`/posts/${post.id}/`}
                    class="block p-4 rounded-xl bg-muted/50 hover:bg-accent/10 transition-all group border border-foreground/5 hover:border-accent/30"
                  >
                    <div class="flex items-start gap-4">
                      <!-- 日期卡片 -->
                      <div class="flex-shrink-0 w-16 h-16 rounded-lg bg-accent text-white flex flex-col items-center justify-center">
                        <span class="text-xs font-medium opacity-90">
                          周{dayNames[dayOfWeek]}
                        </span>
                        <span class="text-2xl font-bold">{day}</span>
                      </div>
                      
                      <!-- 文章信息 -->
                      <div class="flex-1 min-w-0">
                        <div class="font-medium group-hover:text-accent transition-colors line-clamp-2">
                          {post.data.title}
                        </div>
                        <div class="flex items-center gap-3 mt-2 text-sm text-foreground/60">
                          <span>
                            {pubDate.toLocaleDateString('zh-CN', {
                              year: 'numeric',
                              month: 'long',
                              day: 'numeric'
                            })}
                          </span>
                          {post.data.tags?.length > 0 && (
                            <>
                              <span>•</span>
                              <span class="line-clamp-1">{post.data.tags.slice(0, 3).join(', ')}</span>
                            </>
                          )}
                        </div>
                      </div>
                      
                      <!-- 阅读箭头 -->
                      <span class="text-accent text-sm font-medium whitespace-nowrap flex items-center">
                        阅读
                        <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                        </svg>
                      </span>
                    </div>
                  </a>
                );
              })}
            </div>
          </div>
        );
      })}
    </div>
  </Main>
  <Footer />
</Layout>

<script>
  function showDate(dateKey: string) {
    // 可以在这里添加点击日期方块后的交互
    console.log('Clicked date:', dateKey);
  }
</script>
