---
import { getCollection } from "astro:content";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";

const posts = await getCollection("blog");

// 按年月分组
const postsByMonth = new Map<string, any[]>();

posts
  .sort((a, b) => new Date(b.data.pubDatetime).getTime() - new Date(a.data.pubDatetime).getTime())
  .forEach(post => {
    const date = new Date(post.data.pubDatetime);
    const key = `${date.getFullYear()}年${(date.getMonth() + 1).toString().padStart(2, '0')}月`;
    
    if (!postsByMonth.has(key)) {
      postsByMonth.set(key, []);
    }
    postsByMonth.get(key)!.push(post);
  });

// 按年份分组显示
const postsByYear = new Map<number, Array<{ month: string; posts: any[] }>>();

postsByMonth.forEach((posts, month) => {
  const year = parseInt(month.split('年')[0]);
  if (!postsByYear.has(year)) {
    postsByYear.set(year, []);
  }
  postsByYear.get(year)!.push({ month, posts });
});

// 按年份降序排序
const sortedYears = Array.from(postsByYear.keys()).sort((a, b) => b - a);
---

<Layout title={`Archives | ${SITE.title}`}>
  <Header />
  <Main pageTitle="文章归档" pageDesc="按时间浏览博客文章">
    <!-- 快速导航 -->
    <div class="mb-10 p-6 rounded-2xl bg-gradient-to-r from-muted/50 to-muted/30 border border-foreground/10">
      <h3 class="text-xl font-bold mb-4 text-center">📅 快速导航</h3>
      <div class="flex flex-wrap justify-center gap-3">
        {sortedYears.map(year => (
          <a
            href={`#${year}年`}
            class="px-6 py-3 rounded-xl bg-accent text-white font-bold hover:opacity-90 transition-opacity"
          >
            {year}年
          </a>
        ))}
      </div>
      <div class="mt-4 text-center text-foreground/70">
        共 <span class="font-bold text-accent">{posts.length}</span> 篇文章
      </div>
    </div>

    <!-- 按年份归档 -->
    <div class="space-y-12">
      {sortedYears.map(year => {
        const months = postsByYear.get(year)!;
        return (
          <div id={`${year}年`}>
            <h3 class="text-3xl font-bold mb-6 flex items-center gap-3">
              <span class="text-4xl">📆</span>
              <span>{year}年</span>
              <span class="text-lg font-normal text-foreground/60">
                ({months.reduce((sum, m) => sum + m.posts.length, 0)} 篇)
              </span>
            </h3>
            
            <div class="space-y-8">
              {months.map(({ month, posts: monthPosts }) => (
                <div>
                  <h4 class="text-xl font-bold mb-4 text-foreground/70 flex items-center gap-2">
                    <span class="text-2xl">📌</span>
                    {month}
                    <span class="text-sm font-normal text-foreground/50">
                      ({monthPosts.length} 篇)
                    </span>
                  </h4>
                  <div class="space-y-3">
                    {monthPosts.map(post => (
                      <a
                        href={`/posts/${post.id}/`}
                        class="block p-4 rounded-lg bg-muted/50 hover:bg-accent/10 transition-colors group"
                      >
                        <div class="flex items-start justify-between gap-4">
                          <div class="flex-1">
                            <div class="font-medium group-hover:text-accent transition-colors">
                              {post.data.title}
                            </div>
                            <div class="flex items-center gap-3 mt-2 text-sm text-foreground/60">
                              <span>
                                {new Date(post.data.pubDatetime).toLocaleDateString('zh-CN', {
                                  month: 'short',
                                  day: 'numeric'
                                })}
                              </span>
                              {post.data.tags?.length > 0 && (
                                <>
                                  <span>•</span>
                                  <span>{post.data.tags.slice(0, 3).join(', ')}</span>
                                </>
                              )}
                            </div>
                          </div>
                          <span class="text-accent text-sm font-medium whitespace-nowrap">
                            阅读 →
                          </span>
                        </div>
                      </a>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </Main>
  <Footer />
</Layout>
