---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE, FEATURED_PROJECTS } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Projects | ${SITE_TITLE}`} description="My projects and open source work" />
		<style>
			main {
				max-width: 1000px;
				margin: 0 auto;
				padding: 2rem 1rem;
			}
			h1 {
				font-size: 2.5rem;
				margin-bottom: 0.5rem;
				color: #333;
			}
			.subtitle {
				color: #666;
				margin-bottom: 2rem;
				font-size: 1.1rem;
			}
			.projects-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
				gap: 2rem;
			}
			.project-card {
				background: white;
				border: 1px solid #e0e0e0;
				border-radius: 12px;
				padding: 1.5rem;
				transition: transform 0.3s, box-shadow 0.3s;
			}
			.project-card:hover {
				transform: translateY(-5px);
				box-shadow: 0 10px 25px rgba(0,0,0,0.1);
			}
			.project-card h2 {
				color: #667eea;
				margin-bottom: 0.5rem;
				font-size: 1.4rem;
			}
			.project-card p {
				color: #666;
				line-height: 1.6;
				margin-bottom: 1rem;
			}
			.project-tags {
				display: flex;
				gap: 0.5rem;
				flex-wrap: wrap;
				margin-bottom: 1rem;
			}
			.tag {
				background: #667eea;
				color: white;
				padding: 0.3rem 0.8rem;
				border-radius: 15px;
				font-size: 0.85rem;
				font-weight: 500;
			}
			.project-link {
				display: inline-block;
				color: #667eea;
				text-decoration: none;
				font-weight: 600;
				padding: 0.5rem 0;
			}
			.project-link:hover {
				text-decoration: underline;
			}
			.stats {
				display: flex;
				gap: 1.5rem;
				margin-top: 1rem;
				padding-top: 1rem;
				border-top: 1px solid #f0f0f0;
				font-size: 0.9rem;
				color: #888;
			}
		</style>
	</head>
	<body>
		<Header />
		
		<main>
			<h1>🚀 Projects</h1>
			<p class="subtitle">A collection of my open source work and personal projects</p>
			
			<div class="projects-grid">
				{FEATURED_PROJECTS.map((project) => (
					<div class="project-card">
						<h2>{project.name}</h2>
						<div class="project-tags">
							{project.tags.map((tag) => (
								<span class="tag">{tag}</span>
							))}
						</div>
						<p>{project.description}</p>
						<a href={project.repo} class="project-link" target="_blank" rel="noopener">
							View on GitHub →
						</a>
					</div>
				))}
			</div>
		</main>

		<Footer />
	</body>
</html>
